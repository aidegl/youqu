/* pages/profile/profile.wxss */
.container { min-height: 100vh; background: #f5f5f5; }
.profile-header { position: relative; height: 400rpx; overflow: hidden; }
.bg { width: 100%; height: 100%; }
.user-info { 
  position: absolute; 
  bottom: 40rpx; 
  left: 0;
  right: 0;
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  justify-content: center;
}
.avatar { width: 140rpx; height: 140rpx; border-radius: 50%; border: 4rpx solid #fff; margin-bottom: 16rpx; }
.nickname { font-size: 36rpx; font-weight: 600; color: #333; text-align: center; }
.nickname:active { opacity: 0.7; }
.avatar:active { opacity: 0.7; }
.user-id { font-size: 24rpx; color: #666; margin-top: 8rpx; text-align: center; }
.edit-tip { font-size: 22rpx; color: #999; margin-top: 12rpx; text-align: center; }
.stats { display: flex; background: #fff; padding: 30rpx 0; margin-bottom: 20rpx; }
.stat-item { flex: 1; text-align: center; }
.num { display: block; font-size: 36rpx; font-weight: 600; color: #333; }
.label { font-size: 24rpx; color: #999; }
.menu-list { background: #fff; }
.menu-item { display: flex; align-items: center; padding: 30rpx; border-bottom: 1rpx solid #f0f0f0; }
.menu-item .icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-item .text { flex: 1; font-size: 30rpx; color: #333; }
.menu-item .arrow { color: #ccc; font-size: 32rpx; }
.menu-item .badge { background: #ff4d4f; color: #fff; padding: 4rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; margin-right: 16rpx; }
.login-btn { margin: 40rpx; background: #3054EB; color: #fff; border-radius: 44rpx; }
.logout-btn { margin: 40rpx; background: #fff; color: #ff4d4f; border-radius: 44rpx; border: 1rpx solid #ff4d4f; }