<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息 -->
  <view class="profile-header">
    <image class="bg" src="https://fp1.mingdaoyun.cn/customIcon/0_lego.svg" mode="aspectFill"></image>
    <view class="user-info">
      <!-- 头像，可点击修改 -->
      <image class="avatar" src="{{userInfo.avatar || 'https://fp1.mingdaoyun.cn/customIcon/0_lego.svg'}}" bindtap="editAvatar"></image>
      <!-- 昵称，可点击修改 -->
      <text class="nickname" bindtap="editNickname">{{userInfo.nickname || '点击登录'}}</text>
      <text class="user-id">ID: {{userInfo.id || '-'}}</text>
      <!-- 编辑提示 -->
      <text class="edit-tip" wx:if="{{userInfo}}">点击头像/昵称可修改</text>
    </view>
  </view>
  
  <!-- 统计 -->
  <view class="stats">
    <view class="stat-item"><text class="num">12</text><text class="label">发布</text></view>
    <view class="stat-item"><text class="num">5</text><text class="label">粉丝</text></view>
    <view class="stat-item"><text class="num">8</text><text class="label">关注</text></view>
  </view>

  <!-- 菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToMyPosts">
      <text class="icon">📝</text>
      <text class="text">我的发布</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToMessages">
      <text class="icon">💬</text>
      <text class="text">我的消息</text>
      <text class="badge">3</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item">
      <text class="icon">⭐</text>
      <text class="text">我的收藏</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item">
      <text class="icon">⚙️</text>
      <text class="text">设置</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <button class="login-btn" wx:if="{{!userInfo}}" bindtap="login">登录</button>
  
  <!-- 退出登录 -->
  <button class="logout-btn" wx:if="{{userInfo}}" bindtap="logout">退出登录</button>
</view>