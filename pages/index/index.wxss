/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* === 特殊模式（培训）样式 === */

/* 精简版头部 */
.training-header {
  padding: 24rpx 30rpx;
  background: #3054EB;
  color: #fff;
}

.training-title {
  font-size: 32rpx;
  font-weight: 600;
}

.training-progress {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.progress-text {
  font-size: 26rpx;
  margin-right: 20rpx;
}

.progress-bar {
  width: 200rpx;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #4CAF50;
  border-radius: 5rpx;
}

/* 课程列表 */
.course-list {
  padding: 20rpx 30rpx;
}

.course-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.course-item.completed {
  background: #E8F5E9;
}

.course-icon {
  width: 80rpx;
  height: 80rpx;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.course-info {
  flex: 1;
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.course-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.course-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.course-status.done {
  background: #4CAF50;
  color: #fff;
}

.course-status.progress {
  background: #FF9800;
  color: #fff;
}

.course-status.new {
  background: #eee;
  color: #666;
}

.course-desc {
  font-size: 24rpx;
  color: #999;
}

.course-arrow {
  font-size: 32rpx;
  color: #999;
}

/* 底部提示 */
.training-tip {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* === 正常模式（社区）样式 === */
.banner-swiper {
  height: 360rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.category-scroll {
  background: #fff;
  white-space: nowrap;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.category-list {
  display: flex;
  padding: 0 20rpx;
}

.category-item {
  flex-shrink: 0;
  padding: 12rpx 32rpx;
  margin-right: 20rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
}

.category-item.active {
  background: #3054EB;
  color: #fff;
}

.posts-list {
  padding: 20rpx;
}

.post-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.post-cover {
  flex-shrink: 0;
  width: 240rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.post-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.post-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.post-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.post-desc-wrap {
  margin-bottom: 12rpx;
}

.post-desc {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.post-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: auto;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.author-info {
  flex: 1;
}

.author-name {
  font-size: 24rpx;
  color: #333;
}

.post-time {
  font-size: 20rpx;
  color: #999;
}

.post-category {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.post-category.bounty {
  background: #FFF3E0;
  color: #FF9800;
}

.post-category.qa {
  background: #E3F2FD;
  color: #2196F3;
}

.post-category.rant {
  background: #FCE4EC;
  color: #E91E63;
}

.bounty-info {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.bounty-tag {
  font-size: 24rpx;
  color: #FF9800;
}

.bounty-amount {
  font-size: 28rpx;
  color: #FF5722;
  font-weight: 600;
}

.post-footer {
  display: flex;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 12rpx;
}

.footer-item {
  display: flex;
  align-items: center;
  margin-right: 32rpx;
  color: #999;
  font-size: 24rpx;
}

.footer-item .icon {
  margin-right: 6rpx;
}

.loading, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.float-publish-btn {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #3054EB, #4A7AF7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(48, 84, 235, 0.4);
  z-index: 100;
}

.publish-icon {
  color: #fff;
  font-size: 48rpx;
  font-weight: 300;
}