/* pages/publish/publish.wxss */
.container { min-height: 100vh; background: #f5f5f5; padding: 30rpx; }
.form-item { margin-bottom: 30rpx; }
.label { display: block; font-size: 28rpx; color: #333; margin-bottom: 16rpx; font-weight: 500; }
.category-list { display: flex; flex-wrap: wrap; gap: 20rpx; }
.category-btn { padding: 16rpx 32rpx; background: #fff; border: 1rpx solid #ddd; border-radius: 8rpx; font-size: 26rpx; color: #666; }
.category-btn.active { background: #3054EB; color: #fff; border-color: #3054EB; }
.input { width: 100%; padding: 24rpx 20rpx; background: #fff; border: 1rpx solid #ddd; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; height: 88rpx; line-height: 40rpx; }
.textarea { width: 100%; padding: 20rpx; background: #fff; border: 1rpx solid #ddd; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; height: 200rpx; }
.image-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.image-item { position: relative; width: 160rpx; height: 160rpx; }
.image-item image { width: 100%; height: 100%; border-radius: 8rpx; }
.delete-btn { position: absolute; top: -10rpx; right: -10rpx; width: 40rpx; height: 40rpx; background: #ff4d4f; color: #fff; border-radius: 50%; text-align: center; line-height: 40rpx; font-size: 28rpx; }
.add-image { width: 160rpx; height: 160rpx; background: #fff; border: 2rpx dashed #ddd; border-radius: 8rpx; text-align: center; line-height: 160rpx; font-size: 60rpx; color: #999; }
.submit-btn { margin-top: 40rpx; background: #3054EB; color: #fff; border-radius: 44rpx; }