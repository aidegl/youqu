/* pages/profile-space/profile-space.wxss */
.container { min-height: 100vh; background: #f5f5f5; }
.space-header { position: relative; padding-bottom: 120rpx; }
.cover { width: 100%; height: 300rpx; }
.user-section { position: absolute; bottom: 20rpx; left: 0; right: 0; text-align: center; }
.avatar { width: 160rpx; height: 160rpx; border-radius: 50%; border: 4rpx solid #fff; margin-bottom: 16rpx; }
.nickname { display: block; font-size: 36rpx; font-weight: 600; color: #333; }
.user-stats { display: flex; justify-content: center; margin-top: 20rpx; }
.stat { text-align: center; margin: 0 30rpx; }
.stat .num { display: block; font-size: 32rpx; font-weight: 600; }
.stat text { font-size: 24rpx; color: #999; }
.follow-btn { margin-top: 20rpx; padding: 12rpx 60rpx; border: 1rpx solid #FF9800; color: #FF9800; border-radius: 30rpx; font-size: 28rpx; display: inline-block; }
.follow-btn.following { border-color: #999; color: #999; }
.tabs { display: flex; background: #fff; border-bottom: 1rpx solid #eee; }
.tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #666; position: relative; }
.tab.active { color: #3054EB; font-weight: 600; }
.tab.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 40rpx; height: 4rpx; background: #3054EB; }
.album-tab { color: #FF9800; }
.content-list { padding: 20rpx; }
.content-item { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; }
.item-header { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.item-category { padding: 4rpx 12rpx; border-radius: 6rpx; font-size: 22rpx; }
.item-category.bounty { background: #FFF3E0; color: #FF9800; }
.item-category.qa { background: #E3F2FD; color: #2196F3; }
.item-category.rant { background: #FCE4EC; color: #E91E63; }
.item-time { font-size: 24rpx; color: #999; }
.item-title { display: block; font-size: 30rpx; font-weight: 500; color: #333; margin-bottom: 8rpx; }
.item-desc { display: block; font-size: 26rpx; color: #666; margin-bottom: 12rpx; }
.item-footer { display: flex; gap: 24rpx; font-size: 24rpx; color: #999; }
.empty { text-align: center; color: #999; padding: 60rpx; }