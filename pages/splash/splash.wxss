/* pages/splash/splash.wxss */

.splash-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #3054EB 0%, #f5f5f5 100%);
  display: flex;
  flex-direction: column;
}

.nav-placeholder {
  background: #3054EB;
}

.splash-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.logo {
  font-size: 60rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #fff;
  font-size: 28rpx;
}