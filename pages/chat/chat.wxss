/* pages/chat/chat.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* 任务信息 */
.task-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.task-title {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-status {
  font-size: 24rpx;
  color: #FF9800;
  margin-left: 16rpx;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 20rpx 20rpx 20rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.message-item {
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
  padding-right: 20rpx;
  box-sizing: border-box;
}

.message-item.self {
  justify-content: flex-end;
}

.message-item.other {
  justify-content: flex-start;
}

/* 头像 */
.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.message-item.self .msg-avatar {
  margin-left: 16rpx;
}

.message-item.other .msg-avatar {
  margin-right: 16rpx;
}

/* 消息内容区域 */
.msg-content-wrap {
  max-width: 60%;
  display: flex;
  flex-direction: column;
}

.message-item.self .msg-content-wrap {
  align-items: flex-end;
}

.message-item.other .msg-content-wrap {
  align-items: flex-start;
}

.message-bubble {
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  word-break: break-all;
}

.message-item.self .message-bubble {
  background: #3054EB;
}

.message-item.other .message-bubble {
  background: #fff;
}

.message-content {
  font-size: 28rpx;
  line-height: 1.5;
}

.message-item.self .message-content {
  color: #fff;
}

.message-item.other .message-content {
  color: #333;
}

.message-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 输入框 */
.input-box {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.message-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 20rpx;
  width: 120rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FF9800;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  padding: 0;
}