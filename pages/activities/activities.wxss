/* pages/activities/activities.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

/* ========== 页面头部 ========== */
.page-header {
  background: linear-gradient(135deg, #3054EB 0%, #5a6ef0 100%);
  padding: 40rpx 30rpx 60rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ========== 筛选栏 ========== */
.filter-bar {
  background: #fff;
  margin: -40rpx 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.filter-item {
  flex-shrink: 0;
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s;
}

.filter-item.active {
  background: #3054EB;
  color: #fff;
  transform: scale(1.05);
}

/* ========== 活动列表 ========== */
.activity-list {
  padding: 0 30rpx;
}

.activity-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.activity-card:active {
  transform: scale(0.98);
}

/* 活动封面 */
.activity-cover {
  position: relative;
  height: 320rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  overflow: hidden;
}

.activity-cover.no-image {
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.no-image-icon {
  font-size: 120rpx;
  opacity: 0.5;
}

.activity-type {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 24rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 24rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

/* 活动内容 */
.activity-content {
  padding: 30rpx;
}

.activity-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.activity-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 活动信息 */
.activity-info {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.info-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.info-text {
  font-size: 24rpx;
  color: #666;
}

/* 底部操作栏 */
.activity-footer {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.footer-item {
  display: flex;
  align-items: center;
  color: #999;
  font-size: 26rpx;
}

.footer-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.footer-text {
  font-size: 24rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
}

/* ========== 加载状态 ========== */
.loading-state, .no-more {
  text-align: center;
  padding: 40rpx 0;
}

.loading-text, .no-more-text {
  font-size: 26rpx;
  color: #999;
}
