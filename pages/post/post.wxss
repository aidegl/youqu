/* pages/post/post.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 帖子详情 */
.post-detail {
  background: #fff;
  padding: 0;
}

/* 图片（顶部撑满，轮播） */
.post-images {
  width: 100%;
  height: 500rpx;
  border-radius: 0 !important;
}

.post-images .swiper-slide {
  border-radius: 0 !important;
}

.post-image-item {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 0 !important;
}

/* 用户信息 */
.post-header {
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.post-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.follow-btn {
  padding: 10rpx 30rpx;
  border: 1rpx solid #3054EB;
  color: #3054EB;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.post-body {
  padding: 0 30rpx;
  margin-bottom: 24rpx;
}

.post-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.post-content {
  display: block;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.post-images {
  margin-bottom: 24rpx;
}

.post-images image {
  width: 100%;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

/* 悬赏区域 */
.bounty-box {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  margin: 0 30rpx 24rpx;
}

.bounty-tag {
  padding: 8rpx 16rpx;
  background: #FF9800;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.bounty-amount {
  flex: 1;
  font-size: 36rpx;
  color: #FF5722;
  font-weight: 600;
}

.take-btn {
  padding: 16rpx 40rpx;
  background: #3054EB;
  color: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.taken-tip {
  padding: 16rpx 40rpx;
  background: #eee;
  color: #999;
  border-radius: 30rpx;
  font-size: 28rpx;
}

/* 互动按钮 */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 30rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-item {
  display: flex;
  align-items: center;
  color: #666;
  font-size: 28rpx;
}

.action-item .icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.action-item.active {
  color: #FF5722;
}

/* 评论区域 */
.comments-section {
  background: #fff;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.comments-list {
  min-height: 200rpx;
}

.comment-item {
  display: flex;
  margin-bottom: 24rpx;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.comment-author {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.comment-actions {
  display: flex;
  margin-top: 12rpx;
}

.comment-actions .action {
  margin-right: 24rpx;
  font-size: 24rpx;
  color: #999;
}

.no-comment {
  text-align: center;
  color: #999;
  padding: 60rpx 0;
}

/* 底部评论输入 */
.comment-input-box {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 20rpx;
  width: 120rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #3054EB;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  padding: 0;
}