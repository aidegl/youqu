<!--pages/course-detail/course-detail.wxml-->
<view class="container">
  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="height: {{navHeight}}px;">
    <view class="nav-back" bindtap="goBack">←</view>
    <view class="nav-title">{{course.title}}</view>
  </view>

  <!-- 课程概览 -->
  <view class="course-header" wx:if="{{!isLearning && !examMode}}">
    <view class="course-icon">{{course.icon}}</view>
    <view class="course-title">{{course.title}}</view>
    <view class="course-desc">{{course.desc}}</view>
    <view class="course-meta">
      <text class="meta-item">📚 共{{totalChapters}}个章节</text>
      <text class="meta-item">⏱️ 约{{course.duration}}</text>
    </view>
    <view class="course-progress-box">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressPercent}}%"></view>
      </view>
      <text class="progress-text">已学习 {{completedChapters}}/{{totalChapters}} 章节</text>
    </view>
  </view>

  <!-- 章节列表 -->
  <view class="chapter-list" wx:if="{{!isLearning && !examMode}}">
    <view class="section-title">课程章节</view>
    <view class="chapter-item {{item.completed ? 'completed' : ''}}" wx:for="{{chapters}}" wx:key="id" bindtap="startChapter" data-id="{{item.id}}">
      <view class="chapter-status">
        <text wx:if="{{item.completed}}">✓</text>
        <text wx:else>{{item.id}}</text>
      </view>
      <view class="chapter-info">
        <text class="chapter-title">{{item.title}}</text>
        <text class="chapter-duration">{{item.duration}}</text>
      </view>
      <view class="chapter-arrow">›</view>
    </view>
  </view>

  <!-- 开始考试按钮 -->
  <view class="exam-btn-box" wx:if="{{!isLearning && !examMode && allChaptersCompleted}}">
    <button class="exam-btn" bindtap="startExam">参加考试</button>
  </view>

  <!-- 学习内容页 -->
  <view class="learning-page" wx:if="{{isLearning}}">
    <view class="learning-header">
      <view class="learning-back" bindtap="backToCourse">返回课程</view>
      <text class="learning-title">{{currentChapterData.title}}</text>
    </view>
    <scroll-view class="learning-content" scroll-y>
      <view class="content-text">{{currentChapterData.content}}</view>
    </scroll-view>
    <view class="learning-footer">
      <button class="complete-btn" bindtap="completeChapter">完成学习</button>
    </view>
  </view>

  <!-- 考试页面 -->
  <view class="exam-page" wx:if="{{examMode && !showExamResult}}">
    <view class="exam-header">
      <text class="exam-title">{{course.title}} - 考试</text>
      <text class="exam-tip">共{{examQuestions.length}}题，满分100分，80分通过</text>
    </view>
    <scroll-view class="exam-content" scroll-y>
      <view class="question-item" wx:for="{{examQuestions}}" wx:key="id">
        <text class="question-num">{{item.id}}.</text>
        <text class="question-text">{{item.question}}</text>
        <view class="options-list">
          <view class="option-item {{examAnswers[item.id] === index ? 'selected' : ''}}"
                wx:for="{{item.options}}"
                wx:for-index="index"
                wx:for-item="option"
                bindtap="selectAnswer"
                data-qid="{{item.id}}"
                data-aid="{{index}}">
            <text class="option-label">{{optionLabels[index]}}</text>
            <text class="option-text">{{option}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="exam-footer">
      <button class="submit-btn" bindtap="submitExam">提交答案</button>
    </view>
  </view>

  <!-- 考试结果 -->
  <view class="result-page" wx:if="{{showExamResult}}">
    <view class="result-box {{examScore >= 80 ? 'pass' : 'fail'}}">
      <text class="result-icon">{{examScore >= 80 ? '🎉' : '😢'}}</text>
      <text class="result-title">{{examScore >= 80 ? '恭喜通过！' : '未通过考试'}}</text>
      <text class="result-score">得分：{{examScore}}分</text>
      <text class="result-tip" wx:if="{{examScore < 80}}">请重新学习后再次考试</text>
    </view>
    <button class="retry-btn" wx:if="{{examScore < 80}}" bindtap="retryExam">重新考试</button>
    <button class="back-btn" wx:else bindtap="goBack">返回首页</button>
  </view>
</view>