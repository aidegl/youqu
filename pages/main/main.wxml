<!--pages/main/main.wxml-->
<view class="container">
  <!-- 轮播图 -->
  <swiper class="banner-swiper" indicator-dots autoplay circular bindtap="onBannerTap">
    <swiper-item wx:for="{{banners}}" wx:key="id" data-item="{{item}}">
      <image class="banner-image" src="{{item.image}}" mode="aspectFill"></image>
    </swiper-item>
  </swiper>

  <!-- 分类导航 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <view
        class="category-item {{currentCategory === item.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        data-category="{{item.id}}"
        bindtap="switchCategory"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 内容列表 -->
  <view class="posts-list">
    <view
      class="post-card"
      wx:for="{{posts}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToDetail"
    >
      <!-- 左侧封面图 -->
      <view class="post-cover" wx:if="{{item.cover}}">
        <image class="cover-image" src="{{item.cover}}" mode="aspectFill"></image>
      </view>

      <!-- 右侧内容区 -->
      <view class="post-main">
        <!-- 标题 -->
        <view class="post-title-row">
          <text class="post-title">{{item.title}}</text>
          <view class="bounty-info" wx:if="{{item.category === '赏金任务'}}">
            <text class="bounty-tag">【{{item.task_type}}】</text>
            <text class="bounty-amount">¥{{item.bounty_amount}}</text>
          </view>
        </view>

        <!-- 简介 -->
        <view class="post-desc-wrap">
          <text class="post-desc">{{item.content}}</text>
        </view>

        <!-- 用户信息 -->
        <view class="post-header">
          <image
            class="author-avatar"
            src="{{item.author.avatar}}"
          ></image>
          <view class="author-info">
            <text class="author-name">{{item.author.nickname}}</text>
            <text class="post-time">{{item.created_at}}</text>
          </view>
          <view class="post-category {{item.category === '赏金任务' ? 'bounty' : item.category === '问答' ? 'qa' : 'rant'}}">{{item.category}}</view>
        </view>

        <!-- 底部信息 -->
        <view class="post-footer">
          <view class="footer-item">
            <text class="icon">👍</text>
            <text>{{item.likes_count}}</text>
          </view>
          <view class="footer-item">
            <text class="icon">💬</text>
            <text>{{item.comments_count}}</text>
          </view>
          <view class="footer-item">
            <text class="icon">👁️</text>
            <text>{{item.views_count || 0}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore}}">
      <text>没有更多了</text>
    </view>
  </view>

  <!-- 发布按钮 -->
  <view class="float-publish-btn" bindtap="goToPublish">
    <text class="publish-icon">+</text>
  </view>
</view>