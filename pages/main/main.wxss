/* pages/main/main.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 轮播图 */
.banner-swiper {
  height: 360rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-swiper .swiper-pagination-bullet {
  background-color: #cdcdcd;
  opacity: 1;
}

.banner-swiper .swiper-pagination-bullet-active {
  background-color: #1296db;
  opacity: 1;
}

.category-scroll {
  background: #fff;
  white-space: nowrap;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.category-list {
  display: flex;
  padding: 0 20rpx;
}

.category-item {
  flex-shrink: 0;
  padding: 12rpx 32rpx;
  margin-right: 20rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
}

.category-item.active {
  background: #3054EB;
  color: #fff;
}

.posts-list {
  padding: 20rpx;
}

.post-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.post-cover {
  flex-shrink: 0;
  width: 240rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.post-cover .cover-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.post-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.post-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.post-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.3;
}

.post-desc-wrap {
  margin-bottom: 12rpx;
}

.post-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.post-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: auto;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.post-time {
  font-size: 20rpx;
  color: #999;
  margin-top: 2rpx;
}

.post-category {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  flex-shrink: 0;
}

.post-category.bounty {
  background: #FFF3E0;
  color: #FF9800;
}

.post-category.qa {
  background: #E3F2FD;
  color: #2196F3;
}

.post-category.rant {
  background: #FCE4EC;
  color: #E91E63;
}

.bounty-info {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  white-space: nowrap;
}

.bounty-tag {
  font-size: 32rpx;
  color: #FF9800;
  margin-right: 12rpx;
}

.bounty-amount {
  font-size: 32rpx;
  color: #FF5722;
  font-weight: 600;
}

.post-footer {
  display: flex;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.footer-item {
  display: flex;
  align-items: center;
  margin-right: 32rpx;
  color: #999;
  font-size: 24rpx;
}

.footer-item .icon {
  margin-right: 6rpx;
}

.loading, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* 悬浮发布按钮 */
.float-publish-btn {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #3054EB, #4A7AF7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(48, 84, 235, 0.4);
  z-index: 100;
}

.float-publish-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.publish-icon {
  color: #fff;
  font-size: 48rpx;
  font-weight: 300;
}