}

.modal-btns {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn-retry {
  background: #3b82f6;
  color: #ffffff;
  border-radius: 100rpx;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  width: 100%;
}

.btn-cancel {
  background: #f1f5f9;
  color: #64748b;
  border-radius: 100rpx;
  font-size: 30rpx;
  height: 88rpx;
  width: 100%;
}
