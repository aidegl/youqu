page {
  background-color: #f9fafb;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 32rpx;
  box-sizing: border-box;
}

.result-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-bottom: 32rpx;
}

.status-label {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.timer {
  width: 100%;
  height: 64rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
  background-color: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #111827;
  margin-bottom: 16rpx;
}

.result-input {
  flex: 1;
  width: 100%;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background-color: #ffffff;
  color: #111827;
  box-sizing: border-box;
}

.result-input[disabled] {
  color: #111827;
}

.footer {
  width: 100%;
  padding-top: 8rpx;
  padding-bottom: 16rpx;
}

.record-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  background-color: #3b82f6;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 16rpx;
}

.record-btn.recording {
  background-color: #ef4444;
}

.ai-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  background-color: #10b981;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

